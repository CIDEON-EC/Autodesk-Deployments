#!/usr/bin/env sh
set -eu

REPO_ROOT="$(git rev-parse --show-toplevel)"
ANALYZER_SCRIPT="$REPO_ROOT/.scripts/Test-StagedPowerShell.ps1"
PESTER_SCRIPT="$REPO_ROOT/.scripts/Invoke-PesterTests.ps1"

if command -v pwsh >/dev/null 2>&1; then
  PWSH_EXE="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  PWSH_EXE="powershell"
else
  echo "PowerShell executable not found (pwsh/powershell). Commit blocked."
  exit 1
fi

"$PWSH_EXE" -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "$ANALYZER_SCRIPT"
"$PWSH_EXE" -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File "$PESTER_SCRIPT"